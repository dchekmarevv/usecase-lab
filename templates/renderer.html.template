<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{TITLE}} — usecase-lab</title>
<style>
  :root {
    --fg: #111;
    --fg-muted: #6b7280;
    --fg-faint: #9ca3af;
    --bg: #f5f5f4;
    --surface: #fff;
    --border: #e7e5e4;
    --border-strong: #d6d3d1;
    --accent: #2563eb;
    --accent-bg: #eff6ff;
    --accent-strong: #1d4ed8;
    --now: #15803d;
    --next: #b45309;
    --future: #52525b;
    --now-bg: #dcfce7;
    --next-bg: #fef3c7;
    --future-bg: #f4f4f5;
    --top-bg: #fefce8;
    --top-bg-hover: #fef9c3;
    --mono: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    --shadow: 0 1px 2px rgba(0,0,0,0.04);
  }
  * { box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", Roboto, sans-serif;
    background: var(--bg);
    color: var(--fg);
    margin: 0;
    line-height: 1.5;
    font-size: 14px;
  }
  main { max-width: 1440px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
  header { margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 1rem; }
  header h1 { margin: 0 0 0.25rem; font-size: 1.75rem; font-weight: 700; letter-spacing: -0.01em; }
  header .sub { color: var(--fg-muted); font-size: 0.95rem; }
  header .sub a { color: var(--accent); text-decoration: none; }
  header .sub a:hover { text-decoration: underline; }
  .meta { color: var(--fg-faint); font-size: 0.8rem; font-family: var(--mono); }

  section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
    box-shadow: var(--shadow);
  }
  section > h2 { margin: 0 0 1rem; font-size: 1rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem; }
  section > h2 .tag { font-size: 0.7rem; font-weight: 500; color: var(--fg-muted); background: var(--bg); padding: 0.15rem 0.5rem; border-radius: 4px; }

  details summary { cursor: pointer; list-style: none; font-weight: 600; font-size: 1rem; display: flex; align-items: center; gap: 0.5rem; user-select: none; }
  details summary::-webkit-details-marker { display: none; }
  details summary::before { content: "▸"; display: inline-block; color: var(--fg-muted); transition: transform 0.15s; }
  details[open] summary::before { transform: rotate(90deg); }

  .criteria-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 0.75rem; margin-top: 1rem; }
  .criterion { padding: 0.85rem 1rem; background: var(--bg); border-radius: 8px; border-left: 3px solid var(--accent); }
  .criterion h3 { margin: 0 0 0.3rem; font-size: 0.95rem; font-weight: 600; }
  .criterion .q { font-size: 0.85rem; color: var(--fg-muted); margin-bottom: 0.4rem; }
  .rubric { font-family: var(--mono); font-size: 0.72rem; line-height: 1.5; color: var(--fg); }
  .rubric div { display: flex; gap: 0.5rem; }
  .rubric .n { color: var(--accent); font-weight: 700; width: 1rem; }

  .horizons { display: flex; gap: 1rem; margin-top: 1rem; padding-top: 1rem; border-top: 1px dashed var(--border-strong); flex-wrap: wrap; font-size: 0.85rem; }
  .horizons .h-item { display: flex; align-items: center; gap: 0.4rem; }

  .formula {
    font-family: var(--mono);
    font-size: 0.95rem;
    padding: 1rem 1.25rem;
    background: var(--accent-bg);
    border-radius: 8px;
    overflow-x: auto;
    border-left: 3px solid var(--accent);
    line-height: 1.8;
  }
  .formula .w { color: var(--accent-strong); font-weight: 700; }
  .formula .w.zero { color: var(--fg-faint); opacity: 0.5; text-decoration: line-through; }
  .formula .meta-line { margin-top: 0.5rem; font-size: 0.8rem; color: var(--fg-muted); font-family: inherit; }

  .weights-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 0.75rem; }
  .weight-control { background: var(--bg); padding: 0.75rem 0.85rem; border-radius: 8px; }
  .weight-control label { display: block; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--fg-muted); margin-bottom: 0.35rem; font-weight: 600; }
  .weight-control input[type="range"] { width: 100%; margin: 0.25rem 0; accent-color: var(--accent); }
  .weight-control .val { font-family: var(--mono); font-weight: 700; font-size: 1.1rem; color: var(--accent); }
  .weight-control .val .x { color: var(--fg-muted); font-weight: 400; }

  .preset-row { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border); align-items: center; }
  .preset-row .label { font-size: 0.75rem; color: var(--fg-muted); text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600; margin-right: 0.25rem; }
  .preset-buttons { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .btn {
    padding: 0.45rem 0.85rem;
    border: 1px solid var(--border-strong);
    background: var(--surface);
    border-radius: 6px;
    cursor: pointer;
    font-weight: 500;
    font-size: 0.85rem;
    color: var(--fg);
    transition: all 0.1s;
    font-family: inherit;
  }
  .btn:hover { background: var(--accent-bg); border-color: var(--accent); color: var(--accent); }
  .btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn.active:hover { background: var(--accent-strong); color: #fff; }
  .btn.ghost { background: transparent; border-color: transparent; color: var(--fg-muted); }
  .btn.ghost:hover { background: var(--bg); color: var(--fg); border-color: transparent; }

  .leaderboard { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 0.75rem; }
  .lb-card {
    padding: 0.9rem 1rem;
    background: var(--bg);
    border-radius: 8px;
    border-left: 3px solid var(--accent);
    transition: transform 0.1s;
  }
  .lb-card:hover { transform: translateY(-1px); }
  .lb-card .rank { font-size: 0.7rem; color: var(--fg-muted); text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600; }
  .lb-card .score { font-family: var(--mono); font-size: 1.65rem; font-weight: 700; color: var(--accent); line-height: 1; margin: 0.2rem 0 0.35rem; }
  .lb-card .name { font-weight: 600; font-size: 0.9rem; line-height: 1.35; }
  .lb-card .cat { font-size: 0.72rem; color: var(--fg-muted); margin-top: 0.4rem; display: flex; align-items: center; gap: 0.35rem; }

  .filters { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; }
  .filters .search-input {
    flex: 1;
    min-width: 220px;
    padding: 0.55rem 0.85rem;
    border: 1px solid var(--border-strong);
    border-radius: 6px;
    font-size: 0.9rem;
    font-family: inherit;
    background: var(--bg);
  }
  .filters .search-input:focus { outline: 2px solid var(--accent); outline-offset: -1px; background: var(--surface); }
  .chip-group { display: flex; gap: 0.25rem; flex-wrap: wrap; }
  .chip {
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    background: var(--surface);
    font-size: 0.78rem;
    cursor: pointer;
    user-select: none;
    transition: all 0.1s;
  }
  .chip:hover { background: var(--accent-bg); border-color: var(--accent); }
  .chip.active { background: var(--accent); color: #fff; border-color: var(--accent); }

  .table-wrap { overflow-x: auto; border-radius: 10px; }
  table { width: 100%; border-collapse: collapse; font-size: 0.85rem; background: var(--surface); }
  th { text-align: left; padding: 0.6rem 0.5rem; background: var(--bg); font-weight: 600; border-bottom: 2px solid var(--border-strong); font-size: 0.7rem; text-transform: uppercase; color: var(--fg-muted); cursor: pointer; user-select: none; white-space: nowrap; letter-spacing: 0.04em; position: sticky; top: 0; }
  th:hover { color: var(--accent); background: var(--accent-bg); }
  th.sorted { color: var(--accent); }
  th.sorted::after { content: " ↓"; }
  th.sorted.asc::after { content: " ↑"; }
  th.score-col { text-align: center; }
  td { padding: 0.55rem 0.5rem; border-bottom: 1px solid var(--border); vertical-align: top; }
  tr:hover td { background: var(--accent-bg); }
  tr.top-rank td { background: var(--top-bg); }
  tr.top-rank:hover td { background: var(--top-bg-hover); }
  .score-cell { font-family: var(--mono); text-align: center; font-weight: 500; color: var(--fg-muted); }
  .score-cell.highlight { color: var(--fg); font-weight: 700; }
  .total-cell { font-family: var(--mono); text-align: center; font-weight: 700; font-size: 1rem; color: var(--accent); }
  .id-cell { font-family: var(--mono); color: var(--fg-faint); font-size: 0.8rem; }
  .horizon-chip {
    display: inline-block;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    white-space: nowrap;
    background: var(--future-bg);
    color: var(--future);
  }
  .horizon-now { background: var(--now-bg); color: var(--now); }
  .horizon-next { background: var(--next-bg); color: var(--next); }
  .horizon-future { background: var(--future-bg); color: var(--future); }
  .cat-tag { font-size: 0.7rem; color: var(--fg-faint); font-family: var(--mono); margin-top: 0.25rem; }
  .uc-name { font-weight: 600; line-height: 1.35; }
  .uc-desc { color: var(--fg-muted); font-size: 0.82rem; margin-top: 0.2rem; line-height: 1.4; }
  .uc-notes { color: var(--fg-faint); font-size: 0.75rem; margin-top: 0.25rem; font-style: italic; }

  .table-footer { padding: 0.75rem 1rem; background: var(--bg); border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; border-radius: 0 0 10px 10px; }
  .table-footer .count { font-size: 0.8rem; color: var(--fg-muted); }

  footer { text-align: center; color: var(--fg-faint); font-size: 0.75rem; padding: 2rem 0 0; font-family: var(--mono); }
  footer a { color: var(--fg-muted); }

  @media (max-width: 700px) {
    main { padding: 1rem; }
    header h1 { font-size: 1.4rem; }
    section { padding: 1rem; }
    .uc-desc { display: none; }
  }
</style>
</head>
<body>
<main>
  <header>
    <div>
      <h1>{{TITLE}}</h1>
      <div class="sub">Interactive scoring · <a href="https://github.com/dchekmarevv/usecase-lab">usecase-lab</a></div>
    </div>
    <div class="meta">{{DATE}} · {{COUNT}} ideas</div>
  </header>

  <section>
    <details>
      <summary>Framework — criteria, rubrics, horizons</summary>
      <p style="margin-top:1rem; color:var(--fg-muted);">Each use case is scored on each criterion (1-5). Total = weighted sum. Drag the weight sliders below to re-rank in real time.</p>
      <div class="criteria-grid" id="criteria-grid"></div>
      <div class="horizons">
        <span class="h-item"><span class="horizon-chip horizon-now">NOW</span> demoable today</span>
        <span class="h-item"><span class="horizon-chip horizon-next">NEXT</span> 2-4 weeks of work</span>
        <span class="h-item"><span class="horizon-chip horizon-future">FUTURE</span> aspirational / Phase 2+</span>
      </div>
    </details>
  </section>

  <section>
    <h2>Weights <span class="tag">drag to adjust</span></h2>
    <div class="weights-grid" id="weights-grid"></div>
    <div class="preset-row">
      <span class="label">Presets:</span>
      <div class="preset-buttons" id="preset-buttons"></div>
      <button class="btn ghost" id="reset-btn">↻ Reset</button>
    </div>
  </section>

  <section>
    <h2>Formula <span class="tag">live</span></h2>
    <div class="formula" id="formula"></div>
  </section>

  <section>
    <h2>Top 5 by current weights</h2>
    <div class="leaderboard" id="leaderboard"></div>
  </section>

  <section>
    <h2>Filters</h2>
    <div class="filters">
      <input type="text" id="search" class="search-input" placeholder="Search: 'alert', 'onboarding', 'enterprise'...">
    </div>
    <div class="filters" style="margin-top:0.75rem;">
      <span style="font-size:0.75rem; color:var(--fg-muted); text-transform:uppercase; letter-spacing:0.04em; font-weight:600; margin-right:0.25rem;">Horizon:</span>
      <div class="chip-group" id="horizon-chips"></div>
    </div>
    <div class="filters" style="margin-top:0.5rem;">
      <span style="font-size:0.75rem; color:var(--fg-muted); text-transform:uppercase; letter-spacing:0.04em; font-weight:600; margin-right:0.25rem;">Category:</span>
      <div class="chip-group" id="category-chips"></div>
    </div>
  </section>

  <section style="padding:0; overflow:hidden;">
    <div class="table-wrap">
      <table id="uc-table">
        <thead><tr id="table-head-row"></tr></thead>
        <tbody id="uc-tbody"></tbody>
      </table>
    </div>
    <div class="table-footer">
      <span class="count" id="row-count">—</span>
      <button class="btn" id="export-btn">⬇ Export current view to CSV</button>
    </div>
  </section>

  <footer>
    {{TITLE}} · generated {{DATE}} · <a href="https://github.com/dchekmarevv/usecase-lab">usecase-lab</a>
  </footer>
</main>

<script>
const USE_CASES = {{USE_CASES_JSON}};
const CRITERIA = {{CRITERIA_JSON}};
const PRESETS = {{PRESETS_JSON}};

function getPresetWeights(preset) {
  return preset.weights || preset;
}

let weights = {};
if (PRESETS.unweighted) {
  weights = { ...getPresetWeights(PRESETS.unweighted) };
} else {
  CRITERIA.forEach(c => { weights[c.key] = 1; });
}

let sortCol = "total";
let sortDir = "desc";
let search = "";
let horizonFilter = "all";
let categoryFilter = "all";

function calcTotal(uc) {
  return CRITERIA.reduce((s, c) => s + (weights[c.key] || 0) * (Number(uc[c.key]) || 0), 0);
}

function maxTotal() {
  return CRITERIA.reduce((s, c) => s + (weights[c.key] || 0) * 5, 0);
}

function escapeHtml(s) {
  return String(s == null ? "" : s)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function render() {
  const scored = USE_CASES.map(uc => ({ ...uc, total: calcTotal(uc) }));

  let filtered = scored.filter(uc => {
    if (horizonFilter !== "all" && uc.horizon !== horizonFilter) return false;
    if (categoryFilter !== "all" && uc.category !== categoryFilter) return false;
    if (search) {
      const q = search.toLowerCase();
      const hay = [uc.name, uc.description || uc.desc, uc.category, uc.notes].filter(Boolean).join(" ").toLowerCase();
      if (!hay.includes(q)) return false;
    }
    return true;
  });

  filtered.sort((a, b) => {
    let va = a[sortCol], vb = b[sortCol];
    if (typeof va === "string") { va = va.toLowerCase(); vb = vb.toLowerCase(); }
    if (va < vb) return sortDir === "asc" ? -1 : 1;
    if (va > vb) return sortDir === "asc" ? 1 : -1;
    return b.total - a.total;
  });

  renderFormula();
  renderLeaderboard(filtered.slice(0, 5));
  renderTable(filtered);
  updateSortIndicators();
  document.getElementById("row-count").textContent = `${filtered.length} of ${USE_CASES.length}`;
}

function renderFormula() {
  const parts = CRITERIA.map(c => {
    const w = weights[c.key] ?? 0;
    const zeroClass = w === 0 ? "zero" : "";
    return `<span class="w ${zeroClass}">${w}</span>×${escapeHtml(c.key)}`;
  });
  document.getElementById("formula").innerHTML =
    `total = ${parts.join(" + ")}<div class="meta-line">max possible = ${maxTotal()} (when every criterion = 5)</div>`;
}

function renderLeaderboard(top) {
  const el = document.getElementById("leaderboard");
  if (!top.length) { el.innerHTML = "<div style='color:var(--fg-muted); font-size:0.9rem;'>No ideas match current filters.</div>"; return; }
  el.innerHTML = top.map((uc, i) => `
    <div class="lb-card">
      <div class="rank">#${i + 1} · id ${escapeHtml(uc.id)}</div>
      <div class="score">${uc.total}</div>
      <div class="name">${escapeHtml(uc.name)}</div>
      <div class="cat">${escapeHtml(uc.category || "")} · <span class="horizon-chip horizon-${String(uc.horizon || "").toLowerCase()}">${escapeHtml(uc.horizon || "")}</span></div>
    </div>
  `).join("");
}

function renderTableHead() {
  const tr = document.getElementById("table-head-row");
  tr.innerHTML = `
    <th data-sort="id" style="padding-left:1rem;">#</th>
    <th data-sort="name">Use case</th>
    <th data-sort="horizon">Horizon</th>
    ${CRITERIA.map(c => `<th data-sort="${escapeHtml(c.key)}" class="score-col" title="${escapeHtml(c.label)}">${escapeHtml(c.short || c.label)}</th>`).join("")}
    <th data-sort="total" class="score-col sorted" title="Weighted total" style="padding-right:1rem;">Total</th>
  `;
  tr.querySelectorAll("th[data-sort]").forEach(th => {
    th.addEventListener("click", () => {
      const col = th.dataset.sort;
      if (sortCol === col) sortDir = sortDir === "asc" ? "desc" : "asc";
      else { sortCol = col; sortDir = (col === "name" || col === "id") ? "asc" : "desc"; }
      render();
    });
  });
}

function renderTable(rows) {
  const el = document.getElementById("uc-tbody");
  if (!rows.length) { el.innerHTML = `<tr><td colspan="${3 + CRITERIA.length + 1}" style="text-align:center; color:var(--fg-muted); padding:2rem;">No ideas match current filters.</td></tr>`; return; }
  const topTotal = rows[0] && sortCol === "total" && sortDir === "desc" ? rows[0].total : null;
  el.innerHTML = rows.map((uc, i) => {
    const isTop = topTotal !== null && uc.total >= topTotal - 1 && i < 5;
    const notesHtml = uc.notes ? `<div class="uc-notes">${escapeHtml(uc.notes)}</div>` : "";
    const desc = uc.description || uc.desc || "";
    return `
    <tr class="${isTop ? "top-rank" : ""}">
      <td class="id-cell" style="padding-left:1rem;">${escapeHtml(uc.id)}</td>
      <td>
        <div class="uc-name">${escapeHtml(uc.name)}</div>
        <div class="uc-desc">${escapeHtml(desc)}</div>
        ${uc.category ? `<div class="cat-tag">${escapeHtml(uc.category)}</div>` : ""}
        ${notesHtml}
      </td>
      <td><span class="horizon-chip horizon-${String(uc.horizon || "").toLowerCase()}">${escapeHtml(uc.horizon || "")}</span></td>
      ${CRITERIA.map(c => `<td class="score-cell ${(weights[c.key] || 0) > 1 ? "highlight" : ""}">${escapeHtml(uc[c.key] ?? "")}</td>`).join("")}
      <td class="total-cell" style="padding-right:1rem;">${uc.total}</td>
    </tr>`;
  }).join("");
}

function updateSortIndicators() {
  document.querySelectorAll("th[data-sort]").forEach(th => {
    th.classList.remove("sorted", "asc");
    if (th.dataset.sort === sortCol) {
      th.classList.add("sorted");
      if (sortDir === "asc") th.classList.add("asc");
    }
  });
}

function syncWeightInputs() {
  CRITERIA.forEach(c => {
    const input = document.querySelector(`input[data-key="${c.key}"]`);
    const val = document.getElementById(`weight-val-${c.key}`);
    if (input) input.value = weights[c.key] ?? 0;
    if (val) val.textContent = weights[c.key] ?? 0;
  });
}

function detectActivePreset() {
  for (const [name, preset] of Object.entries(PRESETS)) {
    const pw = getPresetWeights(preset);
    let match = true;
    for (const c of CRITERIA) {
      if ((pw[c.key] ?? 0) !== (weights[c.key] ?? 0)) { match = false; break; }
    }
    if (match) return name;
  }
  return null;
}

function updatePresetButtons() {
  const active = detectActivePreset();
  document.querySelectorAll(".preset-buttons button[data-preset]").forEach(b => {
    b.classList.toggle("active", b.dataset.preset === active);
  });
}

function applyPreset(name) {
  const p = PRESETS[name];
  if (!p) return;
  const pw = getPresetWeights(p);
  weights = {};
  CRITERIA.forEach(c => { weights[c.key] = pw[c.key] ?? 0; });
  syncWeightInputs();
  updatePresetButtons();
  render();
}

function renderCriteriaExplainer() {
  const el = document.getElementById("criteria-grid");
  el.innerHTML = CRITERIA.map((c, i) => `
    <div class="criterion">
      <h3>${i + 1}. ${escapeHtml(c.label)}</h3>
      ${c.question ? `<div class="q">${escapeHtml(c.question)}</div>` : ""}
      <div class="rubric">
        ${(c.rubric || []).map(r => `<div><span class="n">${escapeHtml(r[0])}</span>${escapeHtml(r[1])}</div>`).join("")}
      </div>
    </div>
  `).join("");
}

function initWeights() {
  const grid = document.getElementById("weights-grid");
  grid.innerHTML = CRITERIA.map(c => `
    <div class="weight-control">
      <label>${escapeHtml(c.label)}</label>
      <input type="range" min="0" max="3" step="1" value="${weights[c.key] ?? 0}" data-key="${escapeHtml(c.key)}">
      <div class="val"><span id="weight-val-${escapeHtml(c.key)}">${weights[c.key] ?? 0}</span><span class="x">×</span></div>
    </div>
  `).join("");
  grid.querySelectorAll('input[type="range"]').forEach(input => {
    input.addEventListener("input", (e) => {
      const key = e.target.dataset.key;
      weights[key] = parseInt(e.target.value);
      document.getElementById(`weight-val-${key}`).textContent = weights[key];
      updatePresetButtons();
      render();
    });
  });
}

function renderPresetButtons() {
  const el = document.getElementById("preset-buttons");
  el.innerHTML = Object.entries(PRESETS).map(([name, preset]) => `
    <button class="btn" data-preset="${escapeHtml(name)}">${escapeHtml(preset.label || name)}</button>
  `).join("");
  el.querySelectorAll("button[data-preset]").forEach(btn => {
    btn.addEventListener("click", () => applyPreset(btn.dataset.preset));
  });
}

function initFilters() {
  document.getElementById("search").addEventListener("input", (e) => {
    search = e.target.value.trim();
    render();
  });

  const horizons = ["all", "NOW", "NEXT", "FUTURE"];
  document.getElementById("horizon-chips").innerHTML = horizons.map(h => `
    <span class="chip ${h === "all" ? "active" : ""}" data-horizon="${h}">${h === "all" ? "All" : h}</span>
  `).join("");
  document.querySelectorAll("[data-horizon]").forEach(chip => {
    chip.addEventListener("click", () => {
      horizonFilter = chip.dataset.horizon;
      document.querySelectorAll("[data-horizon]").forEach(c => c.classList.remove("active"));
      chip.classList.add("active");
      render();
    });
  });

  const categories = ["all", ...[...new Set(USE_CASES.map(u => u.category).filter(Boolean))].sort()];
  document.getElementById("category-chips").innerHTML = categories.map(c => `
    <span class="chip ${c === "all" ? "active" : ""}" data-category="${escapeHtml(c)}">${c === "all" ? "All" : escapeHtml(String(c).split(".")[0] || c)}</span>
  `).join("");
  document.querySelectorAll("[data-category]").forEach(chip => {
    chip.addEventListener("click", () => {
      categoryFilter = chip.dataset.category;
      document.querySelectorAll("[data-category]").forEach(c => c.classList.remove("active"));
      chip.classList.add("active");
      render();
    });
  });
}

function initPresets() {
  document.getElementById("reset-btn").addEventListener("click", () => {
    if (PRESETS.unweighted) applyPreset("unweighted");
    else {
      CRITERIA.forEach(c => { weights[c.key] = 1; });
      syncWeightInputs();
      updatePresetButtons();
      render();
    }
  });
}

function q(s) { return `"${String(s == null ? "" : s).replace(/"/g, '""')}"`; }

function initExport() {
  document.getElementById("export-btn").addEventListener("click", () => {
    const scored = USE_CASES.map(uc => ({ ...uc, total: calcTotal(uc) }));
    const filtered = scored.filter(uc => {
      if (horizonFilter !== "all" && uc.horizon !== horizonFilter) return false;
      if (categoryFilter !== "all" && uc.category !== categoryFilter) return false;
      if (search) {
        const qs = search.toLowerCase();
        const hay = [uc.name, uc.description || uc.desc, uc.category, uc.notes].filter(Boolean).join(" ").toLowerCase();
        if (!hay.includes(qs)) return false;
      }
      return true;
    });
    filtered.sort((a, b) => {
      let va = a[sortCol], vb = b[sortCol];
      if (typeof va === "string") { va = va.toLowerCase(); vb = vb.toLowerCase(); }
      if (va < vb) return sortDir === "asc" ? -1 : 1;
      if (va > vb) return sortDir === "asc" ? 1 : -1;
      return b.total - a.total;
    });

    const wHeader = CRITERIA.map(c => `w_${c.key}=${weights[c.key] ?? 0}`).join(";");
    const critCols = CRITERIA.map(c => c.key).join(",");
    const header = `# weights: ${wHeader}\n` +
      `id,category,name,description,horizon,${critCols},notes,weighted_total\n`;
    const rows = filtered.map(uc => {
      const critVals = CRITERIA.map(c => uc[c.key] ?? "").join(",");
      return [
        uc.id,
        q(uc.category),
        q(uc.name),
        q(uc.description || uc.desc || ""),
        uc.horizon || "",
        critVals,
        q(uc.notes || ""),
        uc.total
      ].join(",");
    }).join("\n");
    const blob = new Blob([header + rows], { type: "text/csv;charset=utf-8" });
    const a = document.createElement("a");
    const ts = new Date().toISOString().slice(0, 10);
    a.href = URL.createObjectURL(blob);
    a.download = `usecase-lab-${ts}.csv`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
  });
}

renderCriteriaExplainer();
initWeights();
renderPresetButtons();
renderTableHead();
initFilters();
initPresets();
initExport();
updatePresetButtons();
render();
</script>
</body>
</html>
